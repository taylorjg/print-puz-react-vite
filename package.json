{
  "name": "print-puz-react-vite",
  "description": "Print the Private Eye crossword in the style of The Daily Telegraph crossword",
  "private": true,
  "version": "0.0.26",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src cypress --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:cypress": "cypress run",
    "deploy": "gh-pages -d dist",
    "predeploy": "npm run build",
    "open": "open https://taylorjg.github.io/print-puz-react-vite"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@fontsource/roboto": "^5.0.2",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "axios": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/cypress": "^10.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/eslint-plugin": "^1.6.20",
    "cypress": "^15.18.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.9.4",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "eslint-plugin-react": {
      "eslint": "$eslint"
    }
