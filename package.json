{
  "name": "print-puz-react-vite",
  "description": "Print the Private Eye crossword in the style of The Daily Telegraph crossword",
  "private": true,
  "version": "0.0.24",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src cypress --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:cypress": "cypress run",
    "deploy": "gh-pages -d dist",
    "predeploy": "npm run build",
    "open": "open https://taylorjg.github.io/print-puz-react-vite"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@fontsource/roboto": "^5.0.2",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.13.2",
    "axios": "^1.4.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.11.2"
  },
  "devDependencies": {
    "@testing-library/cypress": "^10.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.0.0",
    "cypress": "^12.13.0",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-cypress": "^2.13.3",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-vitest": "^0.2.5",
    "eslint-plugin-vitest-globals": "^1.3.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^26.1.0",
    "msw": "^1.2.1",
    "prettier": "^3.8.4",
    "vite": "^4.3.2",
    "vitest": "^0.31.1"
  }
